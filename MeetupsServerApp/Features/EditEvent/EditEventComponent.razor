@page "/events/edit/{EventId:int}"
@using MeetupsServerApp.Features.DeleteEvent

@inject EditEventService EditEventService
@inject NavigationManager NavigationManager

<PageTitle>
    ویرایش رویداد
</PageTitle>

@if (model is not null)
{
    <AddUpdateEventComponent EventViewModel="model"
                             OnSaved="UpdateEvent"
                             ErrorMessage="errorMessage">
        <ErrorMessageFragment>
            <ErrorMessageComponent ErrorMessage="@errorMessage" />
        </ErrorMessageFragment>
    </AddUpdateEventComponent>

    <DeleteEventComponent EventViewModel="model"
                          ButtonVariant="Variant.Filled"
                          ButtonColor="Color.Error"
                          ButtonText="حذف"
                          OnDeleted="HandleDeletedEventAsync">
    </DeleteEventComponent>
}
else
{
    <ErrorMessageComponent ErrorMessage="خطا در دریافت اطلاعات رویداد" />
}

@code {
    [Parameter]
    public int EventId { get; set; }

    private EventViewModel? model;

    private string? errorMessage = string.Empty;

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            model = await EditEventService.GetEventByIdAsync(EventId);
            await InvokeAsync(StateHasChanged);
            await Task.Delay(1);
        }
    }

    private async Task UpdateEvent()
    {
        errorMessage = model?.Validate();

        if (!string.IsNullOrEmpty(errorMessage))
        {
            return;
        }

        await EditEventService.UpdateEventAsync(model);

        NavigationManager.NavigateTo("/");
    }

    private Task HandleDeletedEventAsync(int eventId)
    {
        NavigationManager.NavigateTo("/");

        return Task.CompletedTask;
    }

}
