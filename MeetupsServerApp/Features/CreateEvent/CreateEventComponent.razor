@page "/events/create"
@using MeetupsServerApp.Features.ViewCreatedEvents
@using System.Globalization
@using System.Reflection


@inject CreateEventService CreateEventService
@inject NavigationManager NavigationManager

<PageTitle>
    ایجاد رویداد
</PageTitle>

<ErrorMessageComponent ErrorMessage="@errorMessage" />

<AddUpdateEventComponent EventViewModel="model"
                         OnSaved="CreateEvent"
                         ErrorMessage="errorMessage">
    <ErrorMessageFragment>
        <ErrorMessageComponent ErrorMessage="@errorMessage" />
    </ErrorMessageFragment>
</AddUpdateEventComponent>

@code {
    EventViewModel model = new EventViewModel();

    private string? errorMessage = string.Empty;

    private async Task CreateEvent()
    {
        errorMessage = model.Validate();

        if (!string.IsNullOrEmpty(errorMessage))
        {
            return;
        }

        await CreateEventService.CreateEventAsync(model);

        NavigationManager.NavigateTo("/");
    }

}
