@page "/events/create"
@using MeetupsServerApp.Features.ViewCreatedEvents
@using System.Globalization
@using System.Reflection

@inject CreateEventService CreateEventService
@inject NavigationManager NavigationManager

<PageTitle>
    ایجاد رویداد
</PageTitle>

<EditForm Model="@model" OnValidSubmit="CreateEvent">
    <DataAnnotationsValidator />
    <ValidationSummary />
    <MudGrid>
        <MudItem xs="12">
            <MudCard>
                <MudCardHeader>
                    <MudText Typo="Typo.h5">
                        ایجاد رویداد
                    </MudText>
                </MudCardHeader>
                <MudCardContent>

                    <MudGrid Spacing="5">
                        <MudItem xs="6">
                            <MudTextField Label="عنوان رویداد"
                                          Variant="Variant.Outlined"
                                          HelperText="حداکثر ۱۰۰ کاراکتر"
                                          @bind-Value="model.Title"
                                          For="@(() => model.Title)" />

                        </MudItem>
                        <MudFlexBreak />
                        <MudItem xs="6">
                            <MudTextField Label="شرح رویداد"
                                          Variant="Variant.Outlined"
                                          Lines="10"
                                          @bind-Value="model.Desription"
                                          For="@(() => model.Desription)" />
                        </MudItem>
                        <MudFlexBreak />
                        <MudItem xs="1">
                            <MudDatePicker Label="تاریخ شروع رویداد"
                                           Variant="Variant.Outlined"
                                           @bind-Date="model.BeginDate"
                                           DateFormat="yyyy/MM/dd"
                                           For="@(() => model.BeginDate)"
                                           Required="true"
                                           RequiredError="واردنمودن تاریخ شروع رویداد الزامی است"
                                           Culture="@GetPersianCulture()"
                                           TitleDateFormat="dddd, dd MMMM" />
                        </MudItem>
                        <MudItem xs="1">
                            <MudTimePicker Label="ساعت شروع رویداد"
                                           Variant="Variant.Outlined"
                                           @bind-Time="model.BeginTime"
                                           Required="true"
                                           RequiredError="واردنمودن ساعت شروع رویداد الزامی است"
                                           For="@(() => model.BeginTime)" />
                        </MudItem>
                        <MudItem xs="1">
                            <MudDatePicker Label="تاریخ خاتمه رویداد"
                                           Variant="Variant.Outlined"
                                           @bind-Date="model.EndDate"
                                           DateFormat="yyyy/MM/dd"
                                           For="@(() => model.EndDate)"
                                           Required="true"
                                           RequiredError="واردنمودن تاریخ خاتمه رویداد الزامی است"
                                           Culture="@GetPersianCulture()"
                                           TitleDateFormat="dddd, dd MMMM" />
                        </MudItem>
                        <MudItem xs="1">
                            <MudTimePicker Label="ساعت خاتمه رویداد"
                                           Variant="Variant.Outlined"
                                           @bind-Time="model.EndTime"
                                           Required="true"
                                           RequiredError="واردنمودن ساعت خاتمه رویداد الزامی است"
                                           For="@(() => model.EndTime)" />
                        </MudItem>
                        <MudFlexBreak />
                        @if (model.Category == MeetupCategoriesEnum.InPerson.ToString())
                        {
                            <MudItem xs="6">
                                <MudTextField Label="مکان برگزاری"
                                              Variant="Variant.Outlined"
                                              @bind-Value="model.Location" />
                            </MudItem>
                        }
                        else if (model.Category == MeetupCategoriesEnum.Online.ToString())
                        {
                            <MudItem xs="6">
                                <MudTextField Label="لینک آدرس"
                                              Variant="Variant.Outlined"
                                              @bind-Value="model.MeetupLink" />
                            </MudItem>
                        }
                        <MudFlexBreak />
                        <MudItem xs="3">
                            <MudFileUpload T="IBrowserFile"
                                           FilesChanged="UploadFiles"
                                           MaximumFileCount="1"
                                           Accept=".png,.jpg,.jpeg">
                                <CustomContent Context="uploadContext">
                                    <MudFab Color="Color.Default"
                                            StartIcon="@Icons.Material.Filled.Image"
                                            OnClick="@uploadContext.OpenFilePickerAsync"
                                            Label="انتخاب تصویر کاور - تصویری با نسبت ۱۶:۹" />
                                </CustomContent>
                            </MudFileUpload>
                        </MudItem>
                        <MudItem xs="6">
                            <MudImage Src="@model.ImageUrl"
                                      Width="300"
                                      Height="169"
                                      Alt="پیش نمایش"
                                      Elevation="2"
                                      ObjectFit="ObjectFit.Cover"
                                      Class="rounded-lg ma-4" />
                        </MudItem>
                    </MudGrid>

                    @if (!string.IsNullOrEmpty(errorMessage))
                    {
                        <MudAlert Severity="Severity.Error"
                                  Dense="true"
                                  Class="my-2">
                            <MudText Typo="Typo.body1">
                                @errorMessage
                            </MudText>
                        </MudAlert>
                    }

                </MudCardContent>
                <MudCardActions>

                    <MudStack Row="true" Spacing="2">
                        <MudButton ButtonType="ButtonType.Submit"
                                   Variant="Variant.Filled"
                                   Color="Color.Success"
                                   Size="Size.Large"
                                   StartIcon="@Icons.Material.TwoTone.SaveAlt">
                            <MudText Typo="Typo.button">
                                ذخیره تغییرات
                            </MudText>
                        </MudButton>

                        <MudButton Variant="Variant.Filled"
                                   Color="Color.Default"
                                   Size="Size.Large"
                                   StartIcon="@Icons.Material.TwoTone.Cancel">
                            <MudText Typo="Typo.button">
                                انصراف
                            </MudText>
                        </MudButton>
                    </MudStack>


                </MudCardActions>
            </MudCard>
        </MudItem>

    </MudGrid>
</EditForm>

@code {
    EventViewModel model = new EventViewModel();

    private string? errorMessage = string.Empty;

    private async Task CreateEvent()
    {
        errorMessage = model.Validate();

        if (!string.IsNullOrEmpty(errorMessage))
        {
            return;
        }

        await CreateEventService.CreateEventAsync(model);

        NavigationManager.NavigateTo("/");
    }

    private async Task UploadFiles(IBrowserFile file)
    {
        if (model is null || file is null)
        {
            return;
        }

        try
        {
            if (file.Size > 500 * 1024)
            {
                errorMessage = "حجم تصویر باید کمتر از ۵۰۰ کیلوبایت باشد.";
                return;
            }
            //تولید نام یکتا
            var fileName = Guid.NewGuid().ToString() + Path.GetExtension(file.Name).ToLower();

            //پردازش و ذخیره تصویر
            model.ImageUrl = await SaveResizedImageAsync(file, fileName);

            errorMessage = string.Empty;
        }
        catch (Exception ex)
        {
            errorMessage = $"خطا در آپلود تصویر : {ex.Message}";
        }
        finally
        {
            await InvokeAsync(StateHasChanged);
        }
    }

    /// <summary>
    /// تصویر را کراپ و ریسایز کرده و ذخیره می‌کند
    /// </summary>
    private async Task<string> SaveResizedImageAsync(IBrowserFile file, string fileName)
    {
        var filePath = Path.Combine("wwwroot", "images", "events", fileName);

        // اطمینان از وجود پوشه
        var directory = Path.GetDirectoryName(filePath);
        if (!Directory.Exists(directory))
            Directory.CreateDirectory(directory!);

        using var stream = file.OpenReadStream(maxAllowedSize: 10 * 1024 * 1024);
        using var ms = new MemoryStream();

        await stream.CopyToAsync(ms);   // ← این خط مهم است
        ms.Position = 0;

        using var originalImage = System.Drawing.Image.FromStream(ms);

        int targetWidth = 300;
        int targetHeight = 169;

        float originalRatio = (float)originalImage.Width / originalImage.Height;
        float targetRatio = (float)targetWidth / targetHeight;

        int cropWidth = originalImage.Width;
        int cropHeight = originalImage.Height;
        int cropX = 0;
        int cropY = 0;

        if (originalRatio > targetRatio)
        {
            cropWidth = (int)(originalImage.Height * targetRatio);
            cropX = (originalImage.Width - cropWidth) / 2;
        }
        else
        {
            cropHeight = (int)(originalImage.Width / targetRatio);
            cropY = (originalImage.Height - cropHeight) / 2;
        }

        // کراپ
        using var croppedBitmap = new System.Drawing.Bitmap(cropWidth, cropHeight);
        using (var g = System.Drawing.Graphics.FromImage(croppedBitmap))
        {
            g.DrawImage(originalImage,
                        new System.Drawing.Rectangle(0, 0, cropWidth, cropHeight),
                        new System.Drawing.Rectangle(cropX, cropY, cropWidth, cropHeight),
                        System.Drawing.GraphicsUnit.Pixel);
        }

        // ریسایز نهایی
        using var resizedImage = new System.Drawing.Bitmap(targetWidth, targetHeight);
        using (var graphics = System.Drawing.Graphics.FromImage(resizedImage))
        {
            graphics.CompositingQuality = System.Drawing.Drawing2D.CompositingQuality.HighQuality;
            graphics.SmoothingMode = System.Drawing.Drawing2D.SmoothingMode.HighQuality;
            graphics.InterpolationMode = System.Drawing.Drawing2D.InterpolationMode.HighQualityBicubic;

            graphics.DrawImage(croppedBitmap, 0, 0, targetWidth, targetHeight);
        }

        // ذخیره
        resizedImage.Save(filePath, System.Drawing.Imaging.ImageFormat.Png);

        return $"/images/events/{fileName}";
    }




    public CultureInfo GetPersianCulture()
    {
        var culture = new CultureInfo("fa-IR");
        DateTimeFormatInfo formatInfo = culture.DateTimeFormat;
        formatInfo.AbbreviatedDayNames = new[] { "ی", "د", "س", "چ", "پ", "ج", "ش" };
        formatInfo.DayNames = new[] { "یکشنبه", "دوشنبه", "سه شنبه", "چهار شنبه", "پنجشنبه", "جمعه", "شنبه" };
        var monthNames = new[]
        {
            "فروردین", "اردیبهشت", "خرداد", "تیر", "مرداد", "شهریور", "مهر", "آبان", "آذر", "دی", "بهمن",
            "اسفند",
            "",
        };
        formatInfo.AbbreviatedMonthNames =
            formatInfo.MonthNames =
                formatInfo.MonthGenitiveNames = formatInfo.AbbreviatedMonthGenitiveNames = monthNames;
        formatInfo.AMDesignator = "ق.ظ";
        formatInfo.PMDesignator = "ب.ظ";
        formatInfo.ShortDatePattern = "yyyy/MM/dd";
        formatInfo.LongDatePattern = "dddd, dd MMMM,yyyy";
        formatInfo.FirstDayOfWeek = DayOfWeek.Saturday;
        Calendar cal = new PersianCalendar();
        FieldInfo fieldInfo = culture.GetType().GetField("calendar", BindingFlags.NonPublic | BindingFlags.Instance);
        if (fieldInfo != null)
            fieldInfo.SetValue(culture, cal);
        FieldInfo info = formatInfo.GetType().GetField("calendar", BindingFlags.NonPublic | BindingFlags.Instance);
        if (info != null)
            info.SetValue(formatInfo, cal);
        culture.NumberFormat.NumberDecimalSeparator = "/";
        culture.NumberFormat.DigitSubstitution = DigitShapes.NativeNational;
        culture.NumberFormat.NumberNegativePattern = 0;
        return culture;
    }

}
